# ============================================
# human-bug-tier — 루트 환경변수 예시
# 복사: copy .env.example .env   (Windows)
#       cp .env.example .env     (macOS/Linux)
#
# 실제 비밀 값은 .env 에만 넣고 커밋하지 마세요.
# 백엔드 전용 상세는 backend/.env.example 도 참고.
# ============================================

# ----- 서버 -----
# Express 포트 (backend/server.js)
PORT=5000
NODE_ENV=development

# ----- MongoDB (필수) -----
# Atlas 예: mongodb+srv://USER:PASS@cluster.mongodb.net/DBNAME
# 루트에 값을 둘 수도 있고, backend/.env 에만 둘 수도 있습니다.
# 주의: 루트에 MONGO_URI= 처럼 빈 값으로 두면, dotenv가 키가 이미 설정됐다고 보고
#       backend/.env 의 실제 URI를 덮어쓰지 못할 수 있습니다. (server.js는 override로 보완)
# 값이 없으면 이 줄을 주석 처리하거나 backend/.env 에만 설정하세요.
MONGO_URI=


# ----- 관리자 시드 (서버 기동 시 생성, 필수) -----
ADMIN_INPUT_ID=admin
ADMIN_INPUT_PW=change-me-to-a-strong-password
ADMIN_NAME=관리자

# ----- JWT (프로덕션 필수: 긴 랜덤 문자열) -----
JWT_SECRET=

# ----- 이메일 (Gmail 앱 비밀번호; 비번 찾기 쓰려면 필수) -----
# 미설정 시 회원가입 즉시 인증, 아이디/비번 찾기 API는 503
EMAIL_USER=
EMAIL_APP_PASSWORD=

# ----- 앱/메일 절대 URL (배포 후 권장) -----
# 로컬 예: http://localhost:5000
# Render 예: https://your-app.onrender.com
APP_URL=http://localhost:5000

# ----- 프론트/PWA 참고용 (선택, 향후 앱·WebView) -----
# 네이티브 앱/별도 정적 호스트에서 API 를 가리킬 때
# PUBLIC_API_URL=https://your-app.onrender.com
# PUBLIC_APP_NAME=휴버대 티어표
