# ============================================
# Node.js 기반 프로젝트 .gitignore
# (human-bug-tier: frontend static + backend Express)
# ============================================

# ============================================
# Node.js / npm / yarn / pnpm
# ============================================
node_modules/

# 로그 및 디버그
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 런타임 데이터
pids
*.pid
*.seed
*.pid.lock

# ============================================
# 환경 변수 (절대 커밋 금지!)
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# .env.example 은 반드시 커밋하세요 (예시용)

# ============================================
# OS 생성 파일
# ============================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Desktop.ini

# ============================================
# IDE / Editor
# ============================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ============================================
# 테스트 / 커버리지
# ============================================
coverage/
.nyc_output/
*.lcov
lib-cov/

# ============================================
# 빌드 / 출력 디렉토리 (프로젝트에 따라)
# ============================================
dist/
build/
out/
.cache/

# ============================================
# 프로젝트 전용 무시 항목
# ============================================
# Grok / MCP 도구 세션 아티팩트
mcps/
terminals/

# GitHub Pages 로컬 임시 배포 폴더 (CI에서는 생성됨)
gh-pages-deploy/

# ============================================
# 기타 Node 관련
# ============================================
.lock-wscript
.npm/
.eslintcache
.node_repl_history
.yarn-integrity

# 서버리스 / 클라우드 관련 (필요시 주석 해제)
# .serverless/
# .fusebox/
# .dynamodb/
