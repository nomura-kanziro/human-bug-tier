# ============================================
# human-bug-tier 백엔드 환경변수
# 이 파일을 .env 로 복사한 후 실제 값을 채워주세요.
# ============================================

# MongoDB (필수)
# MongoDB Atlas 연결 문자열 사용 (mongodb+srv://...)
MONGO_URI=

# 관리자 계정 (서버 시작 시 초기 생성용, 필수)
ADMIN_INPUT_ID=admin
ADMIN_INPUT_PW=your-secure-password
ADMIN_NAME=관리자

# JWT 시크릿 (프로덕션에서는 강력한 랜덤 값으로 설정 권장)
JWT_SECRET=

# 이메일 발송용 Gmail (회원가입 인증, 비밀번호 재설정 등)
# - 설정하면 인증 메일 발송 + 이메일 인증 필요
# - 설정하지 않으면 회원가입 시 바로 인증 처리됨 (isVerified=true)
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# 이메일 내 절대 링크용 기본 URL (Render에서는 헤더로 자동 처리됨)
# 배포 후 수동 설정 가능:
# APP_URL=https://your-app.onrender.com
