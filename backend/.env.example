# ============================================
# human-bug-tier — backend 환경변수 예시
# 복사: copy .env.example .env   (Windows, backend 폴더에서)
#       cp .env.example .env
#
# 실행: cd backend && npm start
# dotenv 로드 순서 (server.js):
#   1) 프로젝트 루트 ../.env
#   2) backend/.env  (같은 키가 있으면 여기가 우선)
# ============================================

# ----- 서버 -----
PORT=5000
NODE_ENV=development

# ----- MongoDB (필수) -----
# MongoDB Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/DBNAME
MONGO_URI=

# ----- 관리자 계정 (서버 시작 시 시드, 필수) -----
ADMIN_INPUT_ID=admin
ADMIN_INPUT_PW=your-secure-password
ADMIN_NAME=관리자

# ----- JWT (프로덕션: 강력한 랜덤 문자열 필수) -----
JWT_SECRET=

# ----- 이메일 (선택, Gmail 앱 비밀번호 권장) -----
# 설정 시: 가입 인증 메일 + 비밀번호 재설정 메일
# 미설정 시: 가입 즉시 isVerified=true
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password

# ----- 이메일/리다이렉트 절대 URL -----
# 로컬: http://localhost:5000
# Render: https://your-app.onrender.com
APP_URL=http://localhost:5000
